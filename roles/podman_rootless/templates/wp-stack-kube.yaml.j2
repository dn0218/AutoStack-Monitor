apiVersion: v1
kind: Pod
metadata:
  name: wp-stack
spec:
  containers:
    - name: mariadb
      image: docker.io/library/mariadb:10.6
      env:
        - name: MARIADB_ROOT_PASSWORD
          value: "password123"
        - name: MARIADB_DATABASE
          value: "wordpress"
        - name: MARIADB_USER
          value: "wpuser"
        - name: MARIADB_PASSWORD
          value: "wppassword"
      volumeMounts:
        - name: db-data
          mountPath: /var/lib/mysql

    - name: redis
      image: docker.io/library/redis:alpine

    - name: wordpress
      image: docker.io/library/wordpress:latest
      env:
        - name: WORDPRESS_DB_HOST
          value: 127.0.0.1
        - name: WORDPRESS_DB_NAME
          value: wordpress
        - name: WORDPRESS_DB_USER
          value: wpuser
        - name: WORDPRESS_DB_PASSWORD
          value: wppassword
      volumeMounts:
        - name: wp-data
          mountPath: /var/www/html

  volumes:
    - name: db-data
      hostPath:
        path: /home/{{ deploy_user }}/data/db
    - name: wp-data
      hostPath:
        path: /home/{{ deploy_user }}/data/wp
